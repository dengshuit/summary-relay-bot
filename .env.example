# PostgreSQL async database URL. Required bootstrap configuration.
DATABASE_URL=postgresql+asyncpg://summary_bot:change-me@postgres:5432/summary_relay_bot

# Encryption key for bot token and LLM API key records. Required bootstrap configuration.
# Generate a deployment-specific value and keep it stable for the database lifetime.
# Example generator:
# python3 -c "from summary_relay_bot.services.secrets import SecretService; print(SecretService.generate_key())"
SETTINGS_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Single WebUI administrator bearer token. Required bootstrap configuration.
WEBUI_ADMIN_TOKEN=replace-with-long-random-admin-token

# WebUI/API listener. The same Python service serves /api/* and the built React app.
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080

# V1 runs with polling. If Telegram reports an active webhook, startup fails unless this is true.
ALLOW_WEBHOOK_DELETE=false

# If webhook deletion is explicitly enabled, keep pending updates by default.
DROP_PENDING_UPDATES_ON_WEBHOOK_DELETE=false

# Raw update JSON payload retention window. Cleanup redacts payloads older than this many days.
RAW_UPDATE_RETENTION_DAYS=30

# Scheduler timezone and restart behavior.
SCHEDULER_TIMEZONE=UTC
SCHEDULER_MISFIRE_GRACE_SECONDS=300
SCHEDULER_COALESCE=true

# Optional Telegram Bot API outbound proxy used by polling, delivery, and Bot validation.
# Examples: socks5://host.docker.internal:7890 or http://proxy:8080
TELEGRAM_API_PROXY=

# Bot token, owner id, LLM provider/API key/model, summary profiles, and group summary settings
# are managed in the database through the WebUI. They are not bootstrap env truth.
